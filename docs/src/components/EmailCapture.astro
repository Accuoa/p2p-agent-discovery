---
const { content } = Astro.props as { content: any };
---
<section data-testid="email-capture" class="mb-12">
  <h2 class="text-sm font-mono uppercase tracking-widest text-slate-500 mb-2">{content.cta.headline}</h2>
  <form
    method="post"
    action={content.email.captureEndpoint}
    class="flex flex-col sm:flex-row gap-2"
  >
    <input type="hidden" name="projectId" value={content.email.projectId} />
    <input
      type="email"
      name="email"
      required
      placeholder={content.cta.secondary.placeholder}
      class="flex-1 px-4 py-2 border rounded font-mono text-sm"
      aria-label="email address"
    />
    <button type="submit" class="px-4 py-2 rounded bg-slate-900 text-white font-semibold hover:bg-slate-700">
      {content.cta.secondary.label}
    </button>
  </form>
  <p class="mt-2 text-xs text-slate-500">
    We'll send a one-time confirmation. See <a href="./privacy" class="underline">privacy</a> and <a href="./terms" class="underline">terms</a>.
  </p>
</section>
